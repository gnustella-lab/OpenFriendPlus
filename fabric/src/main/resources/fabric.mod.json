{
  "schemaVersion": 1,
  "id": "openfriendplus",
  "version": "${version}",
  "name": "OpenFriend Plus",
  "description": "Unofficial enhanced fork of OpenFriendMod with improved UX, privacy options, diagnostics, translations, and modpack-friendly defaults.",
  "authors": ["gnustella-lab"],
  "contributors": ["ZSHARE - original OpenFriendMod author"],
  "contact": {
    "homepage": "https://modrinth.com/mod/openfriend-plus",
    "sources": "https://github.com/gnustella-lab/OpenFriendPlus",
    "issues": "https://github.com/gnustella-lab/OpenFriendPlus/issues"
  },
  "license": "MIT",
  "icon": "assets/openfriendplus/textures/gui/openfriendplus_icon.png",
  "environment": "client",
  "entrypoints": {
    "client": ["dev.gnustella.openfriendplus.fabric.OpenFriendPlusFabricClient"]
  },
  "mixins": [
    "openfriendplus.mixins.json",
    "openfriendplus.fabric.mixins.json"
  ],
  "accessWidener": "openfriendplus.accesswidener",
  "depends": {
    "fabricloader": ">=0.16.0",
    "minecraft": ">=1.16.5",
    "java": ">=17"
  }
}
